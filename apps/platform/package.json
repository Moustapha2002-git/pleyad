{
  "name": "@pleyad/platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"tsx watch server/index.ts\" \"vite\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite",
    "start": "tsx server/index.ts",
    "build": "vite build",
    "check": "tsc --noEmit && tsc -p client/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pleyad/db": "workspace:*",
    "@tanstack/react-query": "^5.90.2",
    "@trpc/client": "^11.6.0",
    "@trpc/react-query": "^11.6.0",
    "@trpc/server": "^11.6.0",
    "cookie": "^1.0.2",
    "dotenv": "^17.2.2",
    "express": "^4.21.2",
    "jose": "^6.1.0",
    "lucide-react": "^0.453.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "superjson": "^1.13.3",
    "wouter": "^3.3.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^24.7.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.19.1",
    "typescript": "5.9.3",
    "vite": "^7.1.7"
  }
}
