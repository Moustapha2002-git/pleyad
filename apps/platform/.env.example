# Pleyad platform (API) — copy to `.env` and fill in. NEVER commit `.env`.
DATABASE_URL="mysql://USER:PASSWORD@HOST:4000/pleyad"
SESSION_SECRET="a-long-random-string"
PORT=3001
NODE_ENV=development

# Daily.co video (optional in dev; falls back to public Jitsi if unset)
DAILY_DOMAIN="yourname.daily.co"
DAILY_API_KEY="your-daily-api-key"
