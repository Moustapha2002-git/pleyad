# Pleyad environment — copy to `.env` and fill in. NEVER commit `.env`.

# ── Database ─────────────────────────────────────────────────────────────
# A FRESH TiDB Cloud database dedicated to Pleyad (separate from Innovation Academy).
# Create the database, then paste its connection string here.
DATABASE_URL="mysql://USER:PASSWORD@HOST:4000/pleyad?ssl={\"rejectUnauthorized\":true}"

# ── Auth (Phase 1, in-house) ─────────────────────────────────────────────
# Generate a strong random value, e.g. `openssl rand -hex 32`
SESSION_SECRET="change-me-to-a-long-random-string"
